# Enforce LF line endings for text files in this repository
* text=auto

# Shell scripts must use LF to be executable in Unix environments
*.sh text eol=lf

# Ruby files
*.rb text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# JavaScript / TypeScript
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# JSON and config files
*.json text eol=lf
*.md text eol=lf
*.env text eol=lf

# Dockerfiles
Dockerfile text eol=lf
*.dockerfile text eol=lf

#Databases
*.sql text eol=lf

# RestructuredText files
*.rst text eol=lf